# API Settings
PROJECT_NAME=LLMAPI
API_V1_STR=/v1

# LLM Inference Settings (OpenAI Compatible)
# Main Engine (e.g., vLLM 70B)
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=not_needed_for_ollama
LLM_MODEL_NAME=llama3.2:3b

# Backup Engine (e.g., local 8B/1B)
LLM_BACKUP_BASE_URL=http://host.docker.internal:11434/v1
LLM_BACKUP_MODEL_NAME=llama3.2:1b

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Operational Settings
LOG_LEVEL=INFO
PROMPT_CONFIG_FILE=src/core/prompts.yaml

# Security
SECRET_KEY=dev_secret_key_change_me_in_prod
ALLOWED_HOSTS=["*"]
