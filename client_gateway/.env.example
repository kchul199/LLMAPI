APP_NAME=LLMAPI Client Gateway
APP_VERSION=0.1.0
API_PREFIX=/client/v1

LLMAPI_BASE_URL=http://localhost:8001/v1
LLMAPI_TIMEOUT_SECONDS=30
DEFAULT_PROMPT_VERSION=v1.1

MYSQL_DSN=mysql+pymysql://root:password@localhost:3306/client_gateway
REDIS_URL=redis://localhost:6379/1
QUEUE_ENABLED=false

AUTH_SHARED_KEY=
LOG_LEVEL=INFO
